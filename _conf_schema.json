{
  "llm_permission_mode": {
    "type": "string",
    "description": "AI管理权限模式",
    "hint": "默认readonly：LLM只能查询。full允许LLM踢人、封禁、OP、执行命令、修改世界和启停实例；模型可能产生幻觉或选错目标，启用后风险与后果由用户自行承担。建议通过 /mc ai-mode 管理并在操作后立即恢复readonly",
    "obvious_hint": true,
    "options": ["readonly", "full"],
    "default": "readonly"
  },
  "default_server": {
    "type": "string",
    "description": "默认服务器ID",
    "hint": "管理工具未明确指定服务器时使用的服务器ID；留空则使用服务器列表中的第一项",
    "default": ""
  },
  "mc_servers": {
    "type": "template_list",
    "description": "Minecraft服务器列表",
    "hint": "统一管理的服务器清单。每台服务器可直接被命令和LLM工具指定；配置后旧版单服连接项不再生效",
    "default": [],
    "templates": {
      "server": {
        "name": "Minecraft服务器",
        "display_item": "server_id",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用此服务器",
            "default": true
          },
          "server_id": {
            "type": "string",
            "description": "服务器ID",
            "hint": "唯一标识，例如 server-1、server-2；用于命令和LLM工具，也可用于可选的聊天转发绑定",
            "default": "survival"
          },
          "display_name": {
            "type": "string",
            "description": "显示名称",
            "hint": "发送消息和列出服务器时展示的名称",
            "default": "生存服"
          },
          "enable_dangerous_commands": {
            "type": "bool",
            "description": "允许危险命令",
            "hint": "是否允许在此服务器执行stop、reload等危险命令，建议保持关闭",
            "default": false
          },
          "rcon": {
            "type": "object",
            "description": "RCON连接",
            "items": {
              "enabled": {
                "type": "bool",
                "description": "启用RCON",
                "default": false
              },
              "host": {
                "type": "string",
                "description": "主机地址",
                "hint": "Minecraft服务器的IP地址或域名",
                "default": "localhost"
              },
              "port": {
                "type": "int",
                "description": "RCON端口",
                "default": 25575
              },
              "password": {
                "type": "string",
                "description": "RCON密码",
                "default": ""
              }
            }
          },
          "websocket": {
            "type": "object",
            "description": "WebSocket/鹊桥连接",
            "items": {
              "enabled": {
                "type": "bool",
                "description": "启用WebSocket",
                "default": false
              },
              "url": {
                "type": "string",
                "description": "WebSocket地址",
                "default": "ws://127.0.0.1:8080/minecraft/ws"
              },
              "token": {
                "type": "string",
                "description": "认证令牌",
                "default": ""
              }
            }
          },
          "message": {
            "type": "object",
            "description": "可选：QQ群消息互通",
            "items": {
              "sync_chat_mc_to_qq": {
                "type": "bool",
                "description": "MC→已绑定QQ群聊天同步",
                "default": false
              },
              "sync_chat_qq_to_mc": {
                "type": "bool",
                "description": "已绑定QQ群→MC聊天同步",
                "default": false
              },
              "forward_llm_responses_to_mc": {
                "type": "bool",
                "description": "AstrBot的LLM回复→MC",
                "hint": "将绑定QQ群中的AI最终回复转发到此服务器，可能产生较多消息，默认关闭",
                "default": false
              },
              "forward_player_events": {
                "type": "bool",
                "description": "转发玩家加入/退出/死亡事件",
                "default": true
              },
              "transport": {
                "type": "string",
                "description": "QQ→MC发送方式",
                "hint": "auto自动选择；也可强制使用RCON或WebSocket",
                "options": ["auto", "rcon", "websocket"],
                "default": "auto"
              },
              "mc_message_prefix": {
                "type": "string",
                "description": "MC→QQ消息前缀",
                "hint": "支持{server}显示名称和{server_id}服务器ID占位符",
                "default": "[MC:{server}]"
              },
              "qq_message_prefix": {
                "type": "string",
                "description": "QQ→MC消息前缀",
                "hint": "支持{server}显示名称和{server_id}服务器ID占位符",
                "default": "[QQ]"
              }
            }
          }
        }
      }
    }
  },
  "server_display_name": {
    "type": "string",
    "description": "旧版单服显示名称",
    "hint": "仅当Minecraft服务器列表为空时使用",
    "default": "默认服务器"
  },
  "rcon_enabled": {
    "type": "bool",
    "description": "旧版单服：启用RCON",
    "hint": "仅当Minecraft服务器列表为空时使用",
    "default": false
  },
  "rcon_host": {
    "type": "string",
    "description": "RCON主机地址",
    "hint": "Minecraft服务器的IP地址或域名",
    "default": "localhost"
  },
  "rcon_port": {
    "type": "int",
    "description": "RCON端口",
    "hint": "Minecraft服务器的RCON端口（默认25575）",
    "default": 25575
  },
  "rcon_password": {
    "type": "string",
    "description": "RCON密码",
    "hint": "Minecraft服务器的RCON密码",
    "default": ""
  },
  "mcsmanager_enabled": {
    "type": "bool",
    "description": "启用MCSManager",
    "hint": "是否启用MCSManager面板管理",
    "default": false
  },
  "mcsmanager_panels": {
    "type": "template_list",
    "description": "MCSManager面板列表",
    "hint": "添加多个MCSManager面板的配置信息",
    "default": [],
    "templates": {
      "panel": {
        "name": "MCSManager面板",
        "display_item": "panel_name",
        "items": {
          "panel_name": {
            "type": "string",
            "description": "面板名称",
            "hint": "面板的标识名称，用于区分不同面板",
            "default": ""
          },
          "url": {
            "type": "string",
            "description": "面板地址",
            "hint": "MCSManager Web面板地址（如http://localhost:23333）",
            "default": ""
          },
          "api_key": {
            "type": "string",
            "description": "API密钥",
            "hint": "MCSManager面板的API密钥；实例列表接口需要具备管理员权限的API密钥",
            "default": ""
          },
          "enable_dangerous_commands": {
            "type": "bool",
            "description": "允许控制台危险命令",
            "hint": "是否允许通过此面板发送stop、reload等危险命令，默认关闭",
            "default": false
          }
        }
      }
    }
  },
  "websocket_enabled": {
    "type": "bool",
    "description": "启用WebSocket",
    "hint": "是否启用WebSocket连接（用于鹊桥模组或自定义适配器）",
    "default": false
  },
  "websocket_url": {
    "type": "string",
    "description": "WebSocket地址",
    "hint": "鹊桥模组或自定义适配器的WebSocket地址",
    "default": "ws://127.0.0.1:8080/minecraft/ws"
  },
  "websocket_token": {
    "type": "string",
    "description": "WebSocket令牌",
    "hint": "WebSocket连接的认证令牌",
    "default": ""
  },
  "admin_ids": {
    "type": "list",
    "description": "管理员列表",
    "hint": "允许使用管理功能的QQ号/MC账号列表。留空则所有写操作被禁用",
    "default": []
  },
  "enable_dangerous_commands": {
    "type": "bool",
    "description": "启用危险命令",
    "hint": "是否启用stop等危险命令。建议保持关闭",
    "default": false
  },
  "enable_chat_response": {
    "type": "bool",
    "description": "旧版单服：LLM回复→MC",
    "hint": "将绑定QQ群中的AI最终回复转发到旧版单服，可能产生较多消息，默认关闭",
    "default": false
  },
  "sync_chat_mc_to_qq": {
    "type": "bool",
    "description": "MC→QQ聊天同步",
    "hint": "是否将MC聊天消息同步到绑定的QQ群",
    "default": false
  },
  "sync_chat_qq_to_mc": {
    "type": "bool",
    "description": "QQ→MC聊天同步",
    "hint": "是否将QQ群消息同步到MC服务器",
    "default": false
  },
  "mc_message_prefix": {
    "type": "string",
    "description": "MC消息前缀",
    "hint": "MC消息在QQ群中的前缀标识",
    "default": "[MC]"
  },
  "qq_message_prefix": {
    "type": "string",
    "description": "QQ消息前缀",
    "hint": "QQ消息在MC中的前缀标识",
    "default": "[QQ]"
  }
}
