{
  "admin_ids": {
    "type": "list",
    "description": "管理员ID列表",
    "hint": "填写可信的AstrBot消息发送者ID（QQ适配器通常填QQ号）。留空则所有写操作被禁用",
    "obvious_hint": true,
    "default": []
  },
  "llm_permission_mode": {
    "type": "string",
    "description": "AI管理权限模式",
    "hint": "readonly：LLM只能查询；full：允许LLM踢人、封禁、OP、执行命令、启停实例。模型可能产生幻觉或选错目标，启用full的风险由用户自行承担",
    "obvious_hint": true,
    "options": ["readonly", "full"],
    "default": "readonly"
  },
  "mc_servers": {
    "type": "template_list",
    "description": "Minecraft服务器列表",
    "hint": "每张卡片代表一台服务器：填写服务器ID、连接信息、绑定QQ群号和消息方向。同一个群号可填写到多台服务器中，形成多对多路由",
    "obvious_hint": true,
    "default": [],
    "templates": {
      "server": {
        "name": "Minecraft服务器",
        "display_item": "server_id",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用此服务器",
            "default": true
          },
          "server_id": {
            "type": "string",
            "description": "服务器ID",
            "hint": "必填且唯一，例如 survival、creative；用于命令和LLM工具",
            "default": ""
          },
          "display_name": {
            "type": "string",
            "description": "显示名称",
            "hint": "发送消息和列出服务器时展示的名称",
            "default": ""
          },
          "qq_group_ids": {
            "type": "list",
            "description": "绑定的QQ群号",
            "hint": "只填写QQ群号，例如 123456789；可添加多个。同一个群号也可填写到其他服务器，实现一个群连接多台服务器",
            "default": []
          },
          "enable_dangerous_commands": {
            "type": "bool",
            "description": "允许危险命令",
            "hint": "是否允许在此服务器执行stop、reload等危险命令，建议保持关闭",
            "default": false
          },
          "rcon": {
            "type": "object",
            "description": "RCON连接",
            "items": {
              "enabled": {
                "type": "bool",
                "description": "启用RCON",
                "default": false
              },
              "host": {
                "type": "string",
                "description": "主机地址",
                "hint": "Minecraft服务器的IP地址或域名",
                "default": "localhost"
              },
              "port": {
                "type": "int",
                "description": "RCON端口",
                "default": 25575
              },
              "password": {
                "type": "string",
                "description": "RCON密码",
                "default": ""
              }
            }
          },
          "websocket": {
            "type": "object",
            "description": "WebSocket/鹊桥连接",
            "items": {
              "enabled": {
                "type": "bool",
                "description": "启用WebSocket",
                "default": false
              },
              "url": {
                "type": "string",
                "description": "WebSocket地址",
                "default": "ws://127.0.0.1:8080/minecraft/ws"
              },
              "token": {
                "type": "string",
                "description": "认证令牌",
                "default": ""
              }
            }
          },
          "message": {
            "type": "object",
            "description": "QQ群消息互通",
            "hint": "以下设置只对上方绑定的QQ群生效；全部关闭时仍可正常使用服务器管理功能",
            "items": {
              "sync_chat_mc_to_qq": {
                "type": "bool",
                "description": "MC→QQ聊天同步",
                "default": false
              },
              "sync_chat_qq_to_mc": {
                "type": "bool",
                "description": "QQ→MC聊天同步",
                "default": false
              },
              "forward_llm_responses_to_mc": {
                "type": "bool",
                "description": "LLM回复→MC",
                "hint": "将绑定QQ群中的AI回复转发到此服务器，可能产生较多消息",
                "default": false
              },
              "forward_player_events": {
                "type": "bool",
                "description": "转发玩家加入/退出/死亡事件",
                "default": true
              },
              "transport": {
                "type": "string",
                "description": "QQ→MC发送方式",
                "hint": "auto自动选择；也可强制使用RCON或WebSocket",
                "options": ["auto", "rcon", "websocket"],
                "default": "auto"
              },
              "mc_message_prefix": {
                "type": "string",
                "description": "MC→QQ消息前缀",
                "hint": "支持{server}显示名称和{server_id}服务器ID占位符",
                "default": "[MC:{server}]"
              },
              "qq_message_prefix": {
                "type": "string",
                "description": "QQ→MC消息前缀",
                "hint": "支持{server}显示名称和{server_id}服务器ID占位符",
                "default": "[QQ]"
              }
            }
          },
          "custom_commands": {
            "type": "template_list",
            "description": "自定义指令模板",
            "hint": "预配置受控指令模板，支持{sender}(绑定游戏ID)和<&参数名&>占位符。管理员手动使用/mc cmd不受LLM模式影响；LLM调用仍需FULL",
            "default": [],
            "templates": {
              "command": {
                "name": "自定义指令",
                "display_item": "name",
                "items": {
                  "name": {
                    "type": "string",
                    "description": "指令名称",
                    "hint": "用于/mc cmd <名称>调用",
                    "default": ""
                  },
                  "description": {
                    "type": "string",
                    "description": "指令说明",
                    "default": ""
                  },
                  "command": {
                    "type": "string",
                    "description": "指令模板",
                    "hint": "支持{sender}和<&参数名&>占位符。例如: tpa {sender} <&target&>",
                    "default": ""
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "default_server": {
    "type": "string",
    "description": "默认服务器ID",
    "hint": "填写上方某台服务器的server_id；留空则使用列表中的第一项",
    "default": ""
  },
  "mcsmanager_panels": {
    "type": "template_list",
    "description": "MCSManager面板列表",
    "hint": "添加MCSManager面板。配置后面板管理功能自动启用，无需额外开关",
    "obvious_hint": true,
    "default": [],
    "templates": {
      "panel": {
        "name": "MCSManager面板",
        "display_item": "panel_name",
        "items": {
          "panel_name": {
            "type": "string",
            "description": "面板名称",
            "hint": "面板的标识名称，用于区分不同面板",
            "default": ""
          },
          "url": {
            "type": "string",
            "description": "面板地址",
            "hint": "MCSManager Web面板地址（如 http://localhost:23333）",
            "default": ""
          },
          "api_key": {
            "type": "string",
            "description": "API密钥",
            "hint": "MCSManager面板的API密钥",
            "default": ""
          },
          "ssl_mode": {
            "type": "string",
            "description": "SSL验证模式",
            "hint": "default=系统CA验证（正规证书）；auto_trust=首次获取并锁定自签名证书（仅在可信网络首次连接）；custom=使用下方可信CA证书；disable=跳过验证（不安全，仅限临时排查）",
            "options": ["default", "auto_trust", "disable", "custom"],
            "default": "default"
          },
          "ssl_cert": {
            "type": "string",
            "description": "自定义CA证书路径",
            "hint": "仅在SSL模式选custom时生效。填写证书文件路径（.pem/.crt）",
            "default": ""
          },
          "enable_dangerous_commands": {
            "type": "bool",
            "description": "允许危险命令",
            "hint": "是否允许通过此面板发送stop、reload等危险命令，默认关闭",
            "default": false
          }
        }
      }
    }
  },
  "mcsmanager_enabled": {
    "type": "bool",
    "description": "启用MCSManager（旧版）",
    "hint": "已废弃，面板列表非空时自动启用",
    "invisible": true,
    "default": false
  },
  "qq_group_bindings": {
    "type": "template_list",
    "description": "旧版QQ群绑定（自动迁移）",
    "hint": "仅用于兼容早期分组式配置。插件会把有效条目自动迁移到对应服务器的QQ群号列表",
    "invisible": true,
    "default": [],
    "templates": {
      "binding": {
        "name": "QQ群绑定",
        "display_item": "group_id",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用此绑定",
            "default": true
          },
          "group_id": {
            "type": "string",
            "description": "QQ群号",
            "default": ""
          },
          "server_ids": {
            "type": "list",
            "description": "绑定的服务器ID列表",
            "default": []
          }
        }
      }
    }
  },
  "server_display_name": {
    "type": "string",
    "description": "旧版单服显示名称",
    "invisible": true,
    "default": "默认服务器"
  },
  "rcon_enabled": {
    "type": "bool",
    "description": "旧版单服：启用RCON",
    "invisible": true,
    "default": false
  },
  "rcon_host": {
    "type": "string",
    "description": "旧版RCON主机地址",
    "invisible": true,
    "default": "localhost"
  },
  "rcon_port": {
    "type": "int",
    "description": "旧版RCON端口",
    "invisible": true,
    "default": 25575
  },
  "rcon_password": {
    "type": "string",
    "description": "旧版RCON密码",
    "invisible": true,
    "default": ""
  },
  "websocket_enabled": {
    "type": "bool",
    "description": "旧版启用WebSocket",
    "invisible": true,
    "default": false
  },
  "websocket_url": {
    "type": "string",
    "description": "旧版WebSocket地址",
    "invisible": true,
    "default": "ws://127.0.0.1:8080/minecraft/ws"
  },
  "websocket_token": {
    "type": "string",
    "description": "旧版WebSocket令牌",
    "invisible": true,
    "default": ""
  },
  "enable_dangerous_commands": {
    "type": "bool",
    "description": "旧版启用危险命令",
    "invisible": true,
    "default": false
  },
  "enable_chat_response": {
    "type": "bool",
    "description": "旧版LLM回复→MC",
    "invisible": true,
    "default": false
  },
  "sync_chat_mc_to_qq": {
    "type": "bool",
    "description": "旧版MC→QQ聊天同步",
    "invisible": true,
    "default": false
  },
  "sync_chat_qq_to_mc": {
    "type": "bool",
    "description": "旧版QQ→MC聊天同步",
    "invisible": true,
    "default": false
  },
  "mc_message_prefix": {
    "type": "string",
    "description": "旧版MC消息前缀",
    "invisible": true,
    "default": "[MC]"
  },
  "qq_message_prefix": {
    "type": "string",
    "description": "旧版QQ消息前缀",
    "invisible": true,
    "default": "[QQ]"
  },
  "ssl_verify": {
    "type": "bool",
    "description": "旧版SSL验证",
    "invisible": true,
    "default": true
  },
  "ssl_auto_trust": {
    "type": "bool",
    "description": "旧版自动信任证书",
    "invisible": true,
    "default": false
  }
}
